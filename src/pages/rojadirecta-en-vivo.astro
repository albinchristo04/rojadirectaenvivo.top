---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQ from '../components/FAQ.astro';
import RelatedMatches from '../components/RelatedMatches.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { getMatches } from '../utils/matches';

const events = getMatches();

const title = 'Rojadirecta en Vivo – Ver Fútbol Online Gratis | Tarjeta Roja TV';
const description = 'Rojadirecta en vivo te permite ver fútbol en vivo gratis hoy. Todos los partidos del día en directo. Mejor que Tarjeta Roja y Pirlo TV.';
const canonicalUrl = 'https://rojadirectaenvivo.top/rojadirecta-en-vivo/';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://rojadirectaenvivo.top/' },
  { name: 'Rojadirecta en Vivo', url: canonicalUrl },
];

const faqs = [
  {
    question: '¿Qué es Rojadirecta en Vivo?',
    answer: 'Rojadirecta en Vivo es la evolución del clásico sitio Rojadirecta. En rojadirectaenvivo.top ofrecemos transmisiones en vivo de todos los partidos del día, gratis y sin registro.',
  },
  {
    question: '¿Rojadirecta todavía funciona?',
    answer: 'El sitio original de Rojadirecta ha tenido problemas de disponibilidad. En rojadirectaenvivo.top mantenemos la misma experiencia con una plataforma actualizada y rápida.',
  },
  {
    question: '¿Cuál es la mejor alternativa a Rojadirecta?',
    answer: 'rojadirectaenvivo.top es la mejor alternativa. Combinamos lo mejor de Rojadirecta, Tarjeta Roja y Pirlo TV con transmisiones actualizadas y múltiples canales por partido.',
  },
  {
    question: '¿Necesito VPN para ver Rojadirecta en Vivo?',
    answer: 'No, rojadirectaenvivo.top funciona sin VPN desde cualquier país. Nuestra plataforma está disponible globalmente sin restricciones geográficas.',
  },
];

const internalLinks = [
  { label: '⚽ Fútbol Libre', href: '/futbol-libre/' },
  { label: '⚽ Fútbol en Vivo', href: '/futbol-en-vivo/' },
  { label: '🟥 Tarjeta Roja', href: '/tarjeta-roja/' },
  { label: '📺 Pirlo TV', href: '/pirlo-tv/' },
  { label: '📅 Partidos de Hoy', href: '/partidos-de-hoy/' },
  { label: '🆓 Fútbol en Vivo Gratis', href: '/futbol-en-vivo-gratis/' },
  { label: '👀 Ver Fútbol Online', href: '/ver-futbol/' },
];
---

<Base title={title} description={description} canonicalUrl={canonicalUrl}>
  <div class="container" style="padding-top: 32px;">
    <Breadcrumb items={breadcrumbs} />

    <section class="keyword-hero">
      <h1 class="keyword-h1">Rojadirecta en Vivo</h1>
      <p class="keyword-sub">Fútbol en vivo gratis — todos los partidos de hoy en directo</p>
    </section>

    <div class="keyword-text">
      <p>
        <strong>Rojadirecta en Vivo</strong> es tu portal definitivo para ver <strong>fútbol en vivo gratis</strong> desde cualquier lugar del mundo.
        Nuestra plataforma te ofrece acceso directo a todos los partidos del día, con múltiples canales de transmisión para que nunca te pierdas un gol.
        Somos la alternativa perfecta a <strong>Tarjeta Roja</strong>, <strong>Pirlo TV</strong> y <strong>RojaDirecta TV</strong>.
      </p>

      <p>
        En <strong>rojadirectaenvivo.top</strong> encontrarás transmisiones en vivo de las mejores ligas del mundo:
        LaLiga Española, Premier League, Serie A, Bundesliga, Liga MX, Liga Profesional Argentina,
        Copa Libertadores, Champions League y muchas más. Todo gratis y sin necesidad de registro.
      </p>

      <p>
        La <strong>roja directa</strong> nunca fue tan fácil de acceder. Con solo un clic puedes ver tu partido favorito
        en vivo y en directo. Nuestros streams se actualizan cada 3 horas para garantizar que siempre tengas
        la información más reciente. Ya sea que busques <strong>rojadirecta</strong>, <strong>tarjeta roja en vivo</strong>
        o <strong>pirlo tv rojadirecta</strong>, aquí encontrarás todo lo que necesitas.
      </p>

      <p>
        No importa si estás en España, Argentina, México, Colombia o cualquier otro país hispanohablante —
        <strong>Rojadirecta en Vivo</strong> funciona en todo el mundo. Ver <strong>futbol en vivo</strong>
        gratis es posible gracias a nuestra red de canales y transmisiones. Disfruta del mejor
        <strong>fútbol en vivo gratis hoy</strong> sin complicaciones.
      </p>
    </div>

    <RelatedMatches matches={events} title="Partidos de Hoy" />

    <FAQ items={faqs} />

    <InternalLinks links={internalLinks} />

    <div style="text-align: center; margin-top: 32px; margin-bottom: 32px;">
      <a href="/" style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
        ← Ver todos los partidos
      </a>
      <span style="margin: 0 16px; color: var(--c-text-muted);">|</span>
      <a href="/hoy/" style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
        Partidos de Hoy →
      </a>
    </div>
  </div>
</Base>
