---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';

import matchDataRaw from '../data/matches.json';

const events = matchDataRaw.events || [];

// Helper: generate slug
function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

// Group matches by league
const grouped: Record<string, any[]> = {};
for (const event of events) {
  const key = event.league || 'Otros';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(event);
}

// Sort matches within each group by time
for (const key in grouped) {
  grouped[key].sort((a: any, b: any) => (a.time || '').localeCompare(b.time || ''));
}

// Get today's date for display
const today = new Date();
const dateStr = today.toLocaleDateString('es-ES', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// League to emoji mapping
const leagueFlags: Record<string, string> = {
  'Laliga': 'рџ‡Єрџ‡ё', 'Laliga 2': 'рџ‡Єрџ‡ё', 'Premier League': 'рџЏґу Ѓ§у Ѓўу ЃҐу Ѓ®у Ѓ§у Ѓї',
  'Serie A': 'рџ‡®рџ‡№', 'Bundesliga': 'рџ‡©рџ‡Є', 'Bundesliga 2': 'рџ‡©рџ‡Є',
  'Ligue 1': 'рџ‡«рџ‡·', 'Ligue 2': 'рџ‡«рџ‡·', 'Eredivisie': 'рџ‡ірџ‡±',
  'Liga Mx': 'рџ‡Ірџ‡Ѕ', 'Liga Endesa': 'рџ‡Єрџ‡ё', 'Torneo LPF': 'рџ‡¦рџ‡·',
  'Copa Libertadores': 'рџЊЋ', 'Champions League': 'рџ‡Єрџ‡є',
  'Liga AUF Uruguaya': 'рџ‡єрџ‡ѕ', 'Liga Betplay Dimayor': 'рџ‡Ёрџ‡ґ',
  'Ecuador Ligapro': 'рџ‡Єрџ‡Ё', 'Premiership': 'рџЏґу Ѓ§у Ѓўу Ѓіу ЃЈу Ѓґу Ѓї',
  'NBA': 'рџ‡єрџ‡ё', 'NHL': 'рџ‡єрџ‡ё', 'NFL': 'рџ‡єрџ‡ё', 'MLB': 'рџ‡єрџ‡ё',
};

const title = 'Rojadirecta en Vivo рџ”ґ FГєtbol en Vivo Gratis | Tarjeta Roja TV Pirlo TV';
const description = 'Ver fГєtbol en vivo gratis hoy. Rojadirecta en vivo, Tarjeta Roja, Pirlo TV - todos los partidos del dГ­a en rojadirectaenvivo.top';
const canonicalUrl = 'https://rojadirectaenvivo.top/';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Rojadirecta en Vivo",
  "url": "https://rojadirectaenvivo.top",
  "description": "Ver fГєtbol en vivo gratis - Rojadirecta, Tarjeta Roja, Pirlo TV",
  "inLanguage": "es",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://rojadirectaenvivo.top/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={websiteSchema}>
  <h1 class="text-3xl md:text-4xl font-black mb-2 text-on-surface">
    Rojadirecta en Vivo вЂ“ FГєtbol en Vivo Gratis Hoy
  </h1>

  <p class="text-on-surface/50 mb-8 text-sm capitalize">{dateStr}</p>

  {events.length === 0 ? (
    <div class="text-center py-16">
      <p class="text-on-surface/50 text-lg">No hay partidos disponibles en este momento.</p>
      <p class="text-on-surface/30 text-sm mt-2">Los partidos se actualizan cada 3 horas.</p>
    </div>
  ) : (
    <div class="space-y-10">
      {Object.entries(grouped).map(([leagueName, leagueMatches]) => (
        <section>
          <div class="flex items-center gap-3 mb-4 pb-3 border-b border-white/5">
            <span class="text-xl">{leagueFlags[leagueName] || 'вљЅ'}</span>
            <h2 class="text-lg font-bold text-on-surface/80">{leagueName}</h2>
            <span class="text-xs text-on-surface/40 ml-auto">{leagueMatches.length} partidos</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {leagueMatches.map((event: any) => {
              const slug = toSlug(event);
              return (
                <MatchCard
                  id={event.id}
                  slug={slug}
                  title={`${event.league}: ${event.teams}`}
                  league={event.league}
                  teams={event.teams}
                  time={event.time}
                  date={event.date}
                  channels={event.channels}
                />
              );
            })}
          </div>
        </section>
      ))}
    </div>
  )}
</Base>
