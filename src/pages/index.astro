---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';

import matchDataRaw from '../data/matches.json';

const events = matchDataRaw.events || [];

// Helper: generate slug
function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

function leagueSlug(league: string) {
  return league.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}

// Group matches by league
const grouped: Record<string, any[]> = {};
for (const event of events) {
  const key = event.league || 'Otros';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(event);
}

// Sort matches within each group by time
for (const key in grouped) {
  grouped[key].sort((a: any, b: any) => (a.time || '').localeCompare(b.time || ''));
}

// League to emoji mapping
const leagueFlags: Record<string, string> = {
  'Laliga': 'рЯЗ™рЯЗЄ', 'Laliga 2': 'рЯЗ™рЯЗЄ', 'Premier League': 'рЯПіу†БІу†БҐу†Б•у†БЃу†БІу†Бњ',
  'Serie A': 'рЯЗЃрЯЗє', 'Bundesliga': 'рЯЗ©рЯЗ™', 'Bundesliga 2': 'рЯЗ©рЯЗ™',
  'Ligue 1': 'рЯЗЂрЯЗЈ', 'Ligue 2': 'рЯЗЂрЯЗЈ', 'Eredivisie': 'рЯЗ≥рЯЗ±',
  'Liga Mx': 'рЯЗ≤рЯЗљ', 'Liga Endesa': 'рЯЗ™рЯЗЄ', 'Torneo LPF': 'рЯЗ¶рЯЗЈ',
  'Copa Libertadores': 'рЯМО', 'Champions League': 'рЯЗ™рЯЗЇ',
  'Liga AUF Uruguaya': 'рЯЗЇрЯЗЊ', 'Liga Betplay Dimayor': 'рЯЗ®рЯЗі',
  'Ecuador Ligapro': 'рЯЗ™рЯЗ®', 'Premiership': 'рЯПіу†БІу†БҐу†Б≥у†Б£у†Біу†Бњ',
  'NBA': 'рЯЗЇрЯЗЄ', 'NHL': 'рЯЗЇрЯЗЄ', 'NFL': 'рЯЗЇрЯЗЄ', 'MLB': 'рЯЗЇрЯЗЄ',
};

// Build ticker text
const tickerText = events.map((e: any) => e.teams).join(' ¬Ј ');

const title = 'Rojadirecta en Vivo рЯФі F√Їtbol Gratis | Tarjeta Roja TV';
const description = 'Ver f√Їtbol en vivo gratis hoy. Rojadirecta en vivo, Tarjeta Roja, Pirlo TV - todos los partidos del d√≠a en rojadirectaenvivo.top';
const canonicalUrl = 'https://rojadirectaenvivo.top/';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Rojadirecta en Vivo",
  "url": "https://rojadirectaenvivo.top",
  "description": "Ver f√Їtbol en vivo gratis - Rojadirecta, Tarjeta Roja, Pirlo TV",
  "inLanguage": "es",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://rojadirectaenvivo.top/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={websiteSchema}>
  <!-- Ticker Bar -->
  {events.length > 0 && (
    <div class="ticker">
      <div class="ticker-label">рЯУ° EN VIVO HOY</div>
      <div class="ticker-track">{tickerText} ¬Ј {tickerText}</div>
    </div>
  )}

  <div class="container" style="padding-top: 32px;">
    <h1 class="keyword-h1" style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 8px;">
      Rojadirecta en Vivo
    </h1>
    <p class="keyword-sub" style="margin-bottom: 32px;">F√Їtbol en vivo gratis вАФ todos los partidos de hoy en directo</p>

    {events.length === 0 ? (
      <div style="text-align: center; padding: 64px 0;">
        <p style="color: var(--c-text-secondary); font-size: 16px;">No hay partidos disponibles en este momento.</p>
        <p style="color: var(--c-text-muted); font-size: 13px; margin-top: 8px;">Los partidos se actualizan cada 3 horas.</p>
      </div>
    ) : (
      <div>
        {Object.entries(grouped).map(([leagueName, leagueMatches]) => (
          <section>
            <div class="country-group-header">
              <span style="font-size: 20px;">{leagueFlags[leagueName] || 'вЪљ'}</span>
              <a href={`/liga/${leagueSlug(leagueName)}/`} class="country-name" style="text-decoration: none; color: inherit;">
                {leagueName}
              </a>
              <div class="divider-line"></div>
              <span class="match-count">{leagueMatches.length} partidos</span>
            </div>

            <div class="match-grid">
              {leagueMatches.map((event: any) => {
                const slug = toSlug(event);
                return (
                  <MatchCard
                    id={event.id}
                    slug={slug}
                    title={`${event.league}: ${event.teams}`}
                    league={event.league}
                    teams={event.teams}
                    time={event.time}
                    date={event.date}
                    channels={event.channels}
                  />
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}

    <!-- SEO Text -->
    <section class="seo-text">
      <h2>Rojadirecta en Vivo вАУ Ver F√Їtbol Gratis</h2>
      <p>
        Bienvenido a <strong>Rojadirecta en Vivo</strong>, tu destino para ver f√Їtbol en vivo gratis hoy.
        Aqu√≠ encontrar√°s todos los partidos del d√≠a transmitidos en directo, igual que en
        <strong>Tarjeta Roja</strong>, <strong>Pirlo TV</strong> y <strong>RojaDirecta TV</strong>.
        Disfruta de la <strong>roja directa</strong> sin cortes y en alta definici√≥n.
      </p>
      <p>
        Seguimos todos los campeonatos en vivo: LaLiga, Premier League, Serie A, Bundesliga,
        Liga MX, Liga Profesional Argentina, Copa Libertadores y mucho m√°s.
        Ver <strong>futbol en vivo</strong> nunca fue tan f√°cil вАФ sin registro, sin pago, gratis.
      </p>
    </section>
  </div>
</Base>
