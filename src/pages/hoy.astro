---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';
import matchDataRaw from '../data/matches.json';

const events = matchDataRaw.events || [];

function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

function leagueSlug(league: string) {
  return league.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}

// Group by league
const grouped: Record<string, any[]> = {};
for (const event of events) {
  const key = event.league || 'Otros';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(event);
}

for (const key in grouped) {
  grouped[key].sort((a: any, b: any) => (a.time || '').localeCompare(b.time || ''));
}

const leagueFlags: Record<string, string> = {
  'Laliga': 'рџ‡Єрџ‡ё', 'Laliga 2': 'рџ‡Єрџ‡ё', 'Premier League': 'рџЏґу Ѓ§у Ѓўу ЃҐу Ѓ®у Ѓ§у Ѓї',
  'Serie A': 'рџ‡®рџ‡№', 'Bundesliga': 'рџ‡©рџ‡Є', 'Bundesliga 2': 'рџ‡©рџ‡Є',
  'Ligue 1': 'рџ‡«рџ‡·', 'Ligue 2': 'рџ‡«рџ‡·', 'Eredivisie': 'рџ‡ірџ‡±',
  'Liga Mx': 'рџ‡Ірџ‡Ѕ', 'Liga Endesa': 'рџ‡Єрџ‡ё', 'Torneo LPF': 'рџ‡¦рџ‡·',
  'Copa Libertadores': 'рџЊЋ', 'Champions League': 'рџ‡Єрџ‡є',
  'Liga AUF Uruguaya': 'рџ‡єрџ‡ѕ', 'Liga Betplay Dimayor': 'рџ‡Ёрџ‡ґ',
  'Ecuador Ligapro': 'рџ‡Єрџ‡Ё', 'Premiership': 'рџЏґу Ѓ§у Ѓўу Ѓіу ЃЈу Ѓґу Ѓї',
  'NBA': 'рџ‡єрџ‡ё', 'NHL': 'рџ‡єрџ‡ё', 'NFL': 'рџ‡єрџ‡ё', 'MLB': 'рџ‡єрџ‡ё',
};

// Today's date for display
const now = new Date();
const todayDisplay = now.toLocaleDateString('es-AR', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});
const todayISO = now.toISOString().split('T')[0];

const title = `Partidos de Hoy en Vivo рџ”ґ ${todayDisplay} | Rojadirecta`;
const description = `Ver todos los partidos de hoy ${todayDisplay} en vivo gratis. ${events.length} partidos disponibles en Rojadirecta en Vivo, Tarjeta Roja, Pirlo TV.`;
const canonicalUrl = 'https://rojadirectaenvivo.top/hoy/';

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Partidos de Hoy - ${todayDisplay}`,
  "description": description,
  "url": canonicalUrl,
  "datePublished": todayISO,
  "dateModified": todayISO,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": events.length,
    "itemListElement": events.map((m: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://rojadirectaenvivo.top/partido/${toSlug(m)}/`,
      "name": m.teams
    }))
  }
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={pageSchema}>
  <div class="container" style="padding-top: 32px;">
    <!-- Breadcrumb -->
    <nav class="match-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>вЂє</span>
      <span>Partidos de Hoy</span>
    </nav>

    <h1 class="keyword-h1" style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 8px;">
      вљЅ Partidos de Hoy en Vivo
    </h1>
    <p class="keyword-sub" style="margin-bottom: 8px;">
      {events.length} partidos disponibles вЂ” ver en vivo gratis hoy
    </p>
    <p style="color: var(--c-text-muted); font-size: 13px; text-align: center; margin-bottom: 32px;">
      рџ“… <time datetime={todayISO}>{todayDisplay}</time> В· Actualizado cada 3 horas
    </p>

    {events.length === 0 ? (
      <div style="text-align: center; padding: 64px 0;">
        <p style="color: var(--c-text-secondary); font-size: 16px;">No hay partidos disponibles en este momento.</p>
        <p style="color: var(--c-text-muted); font-size: 13px; margin-top: 8px;">Los partidos se actualizan cada 3 horas.</p>
      </div>
    ) : (
      <div>
        {Object.entries(grouped).map(([leagueName, leagueMatches]) => (
          <section>
            <div class="country-group-header">
              <span style="font-size: 20px;">{leagueFlags[leagueName] || 'вљЅ'}</span>
              <a href={`/liga/${leagueSlug(leagueName)}/`} class="country-name" style="text-decoration: none; color: inherit;">
                {leagueName}
              </a>
              <div class="divider-line"></div>
              <span class="match-count">{leagueMatches.length} partidos</span>
            </div>

            <div class="match-grid">
              {leagueMatches.map((event: any) => {
                const slug = toSlug(event);
                return (
                  <MatchCard
                    id={event.id}
                    slug={slug}
                    title={`${event.league}: ${event.teams}`}
                    league={event.league}
                    teams={event.teams}
                    time={event.time}
                    date={event.date}
                    channels={event.channels}
                  />
                );
              })}
            </div>
          </section>
        ))}
      </div>
    )}

    <!-- SEO Text -->
    <section class="seo-text">
      <h2>Partidos de Hoy en Vivo вЂ” {todayDisplay}</h2>
      <p>
        Bienvenido a la pГЎgina de <strong>partidos de hoy</strong> en <strong>Rojadirecta en Vivo</strong>.
        AquГ­ encontrarГЎs todos los partidos del dГ­a transmitidos en vivo y en directo. Esta pГЎgina
        se regenera automГЎticamente en cada deploy para mostrarte siempre los eventos mГЎs recientes.
      </p>
      <p>
        No te pierdas ningГєn partido вЂ” desde <strong>LaLiga</strong> y <strong>Premier League</strong>
        hasta <strong>NBA</strong> y <strong>Copa Libertadores</strong>. Todo gratis, sin registro,
        en <strong>rojadirectaenvivo.top</strong>, tu <strong>roja directa</strong> de confianza.
      </p>
    </section>

    <!-- FAQ Section -->
    <section class="seo-text" style="margin-top: 24px;">
      <h3>Preguntas Frecuentes</h3>
      <details style="margin-bottom: 12px;">
        <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
          ВїDГіnde ver los partidos de hoy en vivo gratis?
        </summary>
        <p style="margin-top: 8px;">
          En rojadirectaenvivo.top puedes ver todos los partidos de hoy en vivo gratis.
          Ofrecemos mГєltiples canales de transmisiГіn para cada partido sin necesidad de registro.
        </p>
      </details>
      <details style="margin-bottom: 12px;">
        <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
          ВїCada cuГЎnto se actualizan los partidos?
        </summary>
        <p style="margin-top: 8px;">
          Los partidos se actualizan automГЎticamente cada 3 horas. Vuelve regularmente
          para ver los Гєltimos eventos disponibles.
        </p>
      </details>
      <details>
        <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
          ВїPuedo ver partidos en mi celular?
        </summary>
        <p style="margin-top: 8px;">
          SГ­, rojadirectaenvivo.top estГЎ completamente optimizado para celulares y tablets.
          Puedes ver todos los partidos en vivo desde cualquier dispositivo.
        </p>
      </details>
    </section>
  </div>
</Base>
