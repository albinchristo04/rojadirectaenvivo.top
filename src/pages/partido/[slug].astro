---
import Base from '../../layouts/Base.astro';
import MatchPlayer from '../../components/MatchPlayer.astro';
import MatchCard from '../../components/MatchCard.astro';
import LocalTime from '../../components/LocalTime.astro';
import matchDataRaw from '../../data/matches.json';

const allEvents = matchDataRaw.events || [];

function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

export function getStaticPaths() {
  const events = matchDataRaw.events || [];
  return events.map((event: any) => {
    const desc = `${event.league} ${event.teams}`
      .toLowerCase().trim().replace(/\s+/g, ' ')
      .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
    const slug = `${event.id}-${desc}`;
    return { params: { slug }, props: { event } };
  });
}

const { event } = Astro.props;
const slug = toSlug(event);

const dateParts = (event.date || '').split('-');
const isoDate = dateParts.length === 3 ? `${dateParts[2]}-${dateParts[1]}-${dateParts[0]}` : event.date;

// Parse team names for hero display
const teamNames = (event.teams || 'vs').split(/\s+vs\s+/i);
const teamA = teamNames[0]?.trim() || 'Equipo A';
const teamB = teamNames[1]?.trim() || 'Equipo B';

// Related matches
const relatedMatches = allEvents
  .filter((m: any) => m.id !== event.id)
  .sort((a: any, b: any) => {
    const aScore = a.league === event.league ? 0 : 1;
    const bScore = b.league === event.league ? 0 : 1;
    return aScore - bScore;
  })
  .slice(0, 4);

// Keep title under 70 chars for Bing
const rawTitle = `${event.teams} en Vivo рҹ”ҙ ${event.league} | Rojadirecta`;
const title = rawTitle.length > 70 ? `${event.teams} en Vivo | Rojadirecta`.substring(0, 70) : rawTitle;
const description = `Ver ${event.teams} en vivo gratis. ${event.league} en directo por rojadirecta, tarjeta roja, pirlo tv. Partido en vivo hoy ${event.date}.`;
const canonicalUrl = `https://rojadirectaenvivo.top/partido/${slug}/`;

const sportsEventSchema = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": event.teams,
  "description": `Ver ${event.teams} en vivo gratis. ${event.league} en directo.`,
  "startDate": `${isoDate}T${event.time || '00:00'}-03:00`,
  "sport": "FГәtbol",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": { "@type": "VirtualLocation", "url": canonicalUrl },
  "organizer": { "@type": "Organization", "name": event.league }
};

const langFlags: Record<string, string> = {
  es: 'рҹҮӘрҹҮё', fr: 'рҹҮ«рҹҮ·', gb: 'рҹҮ¬рҹҮ§', de: 'рҹҮ©рҹҮӘ', it: 'рҹҮ®рҹҮ№',
  pt: 'рҹҮөрҹҮ№', nl: 'рҹҮірҹҮұ', us: 'рҹҮәрҹҮё', br: 'рҹҮ§рҹҮ·',
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={sportsEventSchema}>
  <!-- Match Header -->
  <section class="match-header">
    <nav class="match-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>вҖә</span>
      <span>{event.league}</span>
      <span>вҖә</span>
      <span>{event.teams}</span>
    </nav>

    <div class="match-league-badge">
      <span>{event.league}</span>
    </div>

    <div class="match-teams-hero">
      <span class="match-team">{teamA}</span>
      <div class="match-versus">
        <span class="versus-line"></span>
        <span>VS</span>
        <span class="versus-line"></span>
      </div>
      <span class="match-team">{teamB}</span>
    </div>

    <div class="match-time-row">
      <span>рҹ“… {event.date}</span>
      <span>вҖў</span>
      <span class="time-local">рҹ•җ {event.time} ARG</span>
      <span>вҖў</span>
      <LocalTime hour={event.time} date={isoDate} id={String(event.id)} />
    </div>
  </section>

  <!-- Two-column layout -->
  <div class="match-layout">
    <div>
      <!-- Player -->
      <MatchPlayer channels={event.channels} matchTitle={event.teams} />

      <!-- SEO text -->
      <section class="seo-text">
        <h2>Ver {event.teams} en Vivo Gratis</h2>
        <p>
          No te pierdas el partido de <strong>{event.teams}</strong> hoy por <strong>{event.league}</strong>.
          Mira la transmisiГіn en vivo y en directo de este emocionante encuentro en
          <strong>Rojadirecta en Vivo</strong>, tu mejor opciГіn para ver
          <strong>fГәtbol en vivo gratis</strong>, similar a <strong>Tarjeta Roja</strong> y <strong>Pirlo TV</strong>.
        </p>
        <p>
          Disfruta de la <strong>roja directa</strong> del partido {event.teams} de {event.league}
          sin interrupciones. Todos los canales disponibles estГЎn listados arriba вҖ”
          haz clic en cualquier canal para cambiar la transmisiГіn.
          En <strong>rojadirectaenvivo.top</strong> encontrarГЎs todos los partidos del dГӯa en vivo.
        </p>
      </section>
    </div>

    <!-- Sidebar -->
    <aside>
      <div class="sidebar-card">
        <h3 class="sidebar-title">InformaciГіn del Partido</h3>

        <div class="sidebar-row">
          <span>рҹҸҶ</span>
          <span>{event.league}</span>
        </div>
        <div class="sidebar-row">
          <span>рҹ•җ</span>
          <span>{event.time} hora Argentina</span>
        </div>
        <div class="sidebar-row">
          <span>рҹ“…</span>
          <span>{event.date}</span>
        </div>
        <div class="sidebar-row">
          <LocalTime hour={event.time} date={isoDate} id={`sidebar-${event.id}`} />
        </div>

        {event.channels && event.channels.length > 0 && (
          <div>
            <div class="sidebar-divider"></div>
            <h4 class="sidebar-title" style="margin-top:0;">Canales Disponibles</h4>
            <div style="display:flex;flex-wrap:wrap;gap:4px;">
              {event.channels.map((ch: any) => (
                <span class="channel-badge">{langFlags[ch.lang] || 'рҹ“ә'} {ch.name}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      {relatedMatches.length > 0 && (
        <div style="margin-top:24px;">
          <h3 class="sidebar-title">Ver MГЎs Partidos</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            {relatedMatches.map((m: any) => {
              const mSlug = toSlug(m);
              return (
                <MatchCard
                  id={m.id}
                  slug={mSlug}
                  title={`${m.league}: ${m.teams}`}
                  league={m.league}
                  teams={m.teams}
                  time={m.time}
                  date={m.date}
                  channels={m.channels}
                />
              );
            })}
          </div>
        </div>
      )}
    </aside>
  </div>
</Base>
