---
import Base from '../../layouts/Base.astro';
import MatchPlayer from '../../components/MatchPlayer.astro';
import MatchCard from '../../components/MatchCard.astro';
import LocalTime from '../../components/LocalTime.astro';
import matchDataRaw from '../../data/matches.json';

const allEvents = matchDataRaw.events || [];

function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

export function getStaticPaths() {
  const events = matchDataRaw.events || [];
  return events.map((event: any) => {
    const desc = `${event.league} ${event.teams}`
      .toLowerCase().trim().replace(/\s+/g, ' ')
      .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
    const slug = `${event.id}-${desc}`;
    return { params: { slug }, props: { event } };
  });
}

const { event } = Astro.props;
const slug = toSlug(event);

const dateParts = (event.date || '').split('-');
const isoDate = dateParts.length === 3 ? `${dateParts[2]}-${dateParts[1]}-${dateParts[0]}` : event.date;

// Parse team names for hero display
const teamNames = (event.teams || 'vs').split(/\s+vs\s+/i);
const teamA = teamNames[0]?.trim() || 'Equipo A';
const teamB = teamNames[1]?.trim() || 'Equipo B';

// Related matches
const relatedMatches = allEvents
  .filter((m: any) => m.id !== event.id)
  .sort((a: any, b: any) => {
    const aScore = a.league === event.league ? 0 : 1;
    const bScore = b.league === event.league ? 0 : 1;
    return aScore - bScore;
  })
  .slice(0, 4);

// Keep title under 70 chars for Bing
const rawTitle = `${event.teams} en Vivo 🔴 ${event.league} | Rojadirecta`;
const title = rawTitle.length > 70 ? `${event.teams} en Vivo | Rojadirecta`.substring(0, 70) : rawTitle;
const description = `Ver ${event.teams} en vivo gratis. ${event.league} en directo por rojadirecta, tarjeta roja, pirlo tv. Partido en vivo hoy ${event.date}.`;
const canonicalUrl = `https://rojadirectaenvivo.top/partido/${slug}/`;

// Detect sport from league name for richer schema
const leagueLower = (event.league || '').toLowerCase();
function detectSport(league: string): string {
  if (/nba|basketball|baloncesto/i.test(league)) return 'Basketball';
  if (/nhl|hockey/i.test(league)) return 'Ice Hockey';
  if (/nfl|football americano/i.test(league)) return 'American Football';
  if (/mlb|baseball|béisbol/i.test(league)) return 'Baseball';
  if (/ufc|mma|boxeo|boxing/i.test(league)) return 'Combat Sport';
  if (/f1|formula|motogp|nascar/i.test(league)) return 'Motorsport';
  if (/atp|wta|tennis|tenis/i.test(league)) return 'Tennis';
  return 'Football';
}
const detectedSport = detectSport(event.league);

function leagueSlug(league: string) {
  return league.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}
function teamSlugFn(name: string) {
  return name.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}
const currentLeagueSlug = leagueSlug(event.league);
const teamASlug = teamSlugFn(teamA);
const teamBSlug = teamSlugFn(teamB);

// Fresh content date for Bing
const publishDate = `${isoDate}T${event.time || '00:00'}:00-03:00`;

const sportsEventSchema = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": event.teams,
  "description": `Ver ${event.teams} en vivo gratis. ${event.league} en directo.`,
  "startDate": `${isoDate}T${event.time || '00:00'}-03:00`,
  "sport": detectedSport,
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": { "@type": "VirtualLocation", "url": canonicalUrl },
  "organizer": { "@type": "Organization", "name": event.league },
  "homeTeam": { "@type": "SportsTeam", "name": teamA, "url": `https://rojadirectaenvivo.top/equipo/${teamASlug}/` },
  "awayTeam": { "@type": "SportsTeam", "name": teamB, "url": `https://rojadirectaenvivo.top/equipo/${teamBSlug}/` }
};

// BreadcrumbList schema for Bing crawl understanding
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://rojadirectaenvivo.top/" },
    { "@type": "ListItem", "position": 2, "name": event.league, "item": `https://rojadirectaenvivo.top/liga/${currentLeagueSlug}/` },
    { "@type": "ListItem", "position": 3, "name": event.teams, "item": canonicalUrl }
  ]
};

// FAQ structured data for Bing rich results
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `¿Dónde ver ${event.teams} en vivo?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Puedes ver ${event.teams} en vivo gratis en rojadirectaenvivo.top. Ofrecemos ${event.channels?.length || 0} canales de transmisión para este partido de ${event.league}.`
      }
    },
    {
      "@type": "Question",
      "name": `¿A qué hora juega ${event.teams}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `El partido ${event.teams} se juega el ${event.date} a las ${event.time} hora Argentina. Consulta tu hora local en la página del partido.`
      }
    },
    {
      "@type": "Question",
      "name": `¿En qué canal transmiten ${event.teams}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `El partido ${event.teams} se transmite por ${event.channels?.length || 0} canales disponibles en rojadirectaenvivo.top. Haz clic en cualquier canal para ver la transmisión en vivo.`
      }
    }
  ]
};

// Speakable schema for Bing Copilot / AI citation
const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".seo-text", ".match-teams-hero", ".faq-section"]
  },
  "url": canonicalUrl
};

const langFlags: Record<string, string> = {
  es: '🇪🇸', fr: '🇫🇷', gb: '🇬🇧', de: '🇩🇪', it: '🇮🇹',
  pt: '🇵🇹', nl: '🇳🇱', us: '🇺🇸', br: '🇧🇷',
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={sportsEventSchema} ogImage="https://rojadirectaenvivo.top/og-default.png">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <!-- Match Header -->
  <section class="match-header">
    <nav class="match-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href={`/liga/${currentLeagueSlug}/`}>{event.league}</a>
      <span>›</span>
      <span>{event.teams}</span>
    </nav>

    <div class="match-league-badge">
      <span>{event.league}</span>
    </div>

    <div class="match-teams-hero">
      <span class="match-team">{teamA}</span>
      <div class="match-versus">
        <span class="versus-line"></span>
        <span>VS</span>
        <span class="versus-line"></span>
      </div>
      <span class="match-team">{teamB}</span>
    </div>

    <div class="match-time-row">
      <span>📅 <time datetime={publishDate}>{event.date}</time></span>
      <span>•</span>
      <span class="time-local">🕐 {event.time} ARG</span>
      <span>•</span>
      <LocalTime hour={event.time} date={isoDate} id={String(event.id)} />
    </div>
    <p class="match-published" style="color: var(--c-text-muted); font-size: 12px; margin-top: 8px; text-align: center;">
      Publicado: <time datetime={publishDate}>{event.date} {event.time}</time> · Actualizado cada 3 horas
    </p>
  </section>

  <!-- Two-column layout -->
  <div class="match-layout">
    <div>
      <!-- Player -->
      <MatchPlayer channels={event.channels} matchTitle={event.teams} />

      <!-- SEO text -->
      <section class="seo-text">
        <h2>Ver {event.teams} en Vivo Gratis</h2>
        <p>
          No te pierdas el partido de <strong>{event.teams}</strong> hoy por <strong>{event.league}</strong>.
          Mira la transmisión en vivo y en directo de este emocionante encuentro en
          <strong>Rojadirecta en Vivo</strong>, tu mejor opción para ver
          <strong>fútbol en vivo gratis</strong>, similar a <strong>Tarjeta Roja</strong> y <strong>Pirlo TV</strong>.
        </p>
        <p>
          Disfruta de la <strong>roja directa</strong> del partido {event.teams} de {event.league}
          sin interrupciones. Todos los canales disponibles están listados arriba —
          haz clic en cualquier canal para cambiar la transmisión.
          En <strong>rojadirectaenvivo.top</strong> encontrarás todos los partidos del día en vivo.
        </p>
      </section>

      <!-- FAQ Section -->
      <section class="seo-text faq-section" style="margin-top: 24px;">
        <h3>Preguntas Frecuentes</h3>
        <details style="margin-bottom: 12px;" open>
          <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
            ¿Dónde ver {event.teams} en vivo?
          </summary>
          <p style="margin-top: 8px;">
            Puedes ver {event.teams} en vivo gratis en rojadirectaenvivo.top.
            Ofrecemos {event.channels?.length || 0} canales de transmisión para este partido
            de {event.league}. Haz clic en cualquier canal de la lista para iniciar la transmisión.
          </p>
        </details>
        <details style="margin-bottom: 12px;">
          <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
            ¿A qué hora juega {event.teams}?
          </summary>
          <p style="margin-top: 8px;">
            El partido {event.teams} se juega el {event.date} a las {event.time} hora Argentina.
            Consulta la hora local en tu zona en la parte superior de esta página.
          </p>
        </details>
        <details>
          <summary style="cursor: pointer; font-weight: 600; color: var(--c-text-primary);">
            ¿En qué canal transmiten {event.teams}?
          </summary>
          <p style="margin-top: 8px;">
            El partido se transmite por {event.channels?.length || 0} canales disponibles
            en rojadirectaenvivo.top. Todos los canales son gratuitos y no requieren registro.
          </p>
        </details>
      </section>

      <!-- Internal links -->
      <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px;">
        <a href={`/liga/${currentLeagueSlug}/`} style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
          🏆 Más partidos de {event.league}
        </a>
        <a href={`/equipo/${teamASlug}/`} style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
          ⚽ {teamA}
        </a>
        <a href={`/equipo/${teamBSlug}/`} style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
          ⚽ {teamB}
        </a>
        <a href="/hoy/" style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
          📅 Partidos de Hoy
        </a>
      </div>
    </div>

    <!-- Sidebar -->
    <aside>
      <div class="sidebar-card">
        <h3 class="sidebar-title">Información del Partido</h3>

        <div class="sidebar-row">
          <span>🏆</span>
          <span>{event.league}</span>
        </div>
        <div class="sidebar-row">
          <span>🕐</span>
          <span>{event.time} hora Argentina</span>
        </div>
        <div class="sidebar-row">
          <span>📅</span>
          <span>{event.date}</span>
        </div>
        <div class="sidebar-row">
          <LocalTime hour={event.time} date={isoDate} id={`sidebar-${event.id}`} />
        </div>

        {event.channels && event.channels.length > 0 && (
          <div>
            <div class="sidebar-divider"></div>
            <h4 class="sidebar-title" style="margin-top:0;">Canales Disponibles</h4>
            <div style="display:flex;flex-wrap:wrap;gap:4px;">
              {event.channels.map((ch: any) => (
                <span class="channel-badge">{langFlags[ch.lang] || '📺'} {ch.name}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      {relatedMatches.length > 0 && (
        <div style="margin-top:24px;">
          <h3 class="sidebar-title">Ver Más Partidos</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            {relatedMatches.map((m: any) => {
              const mSlug = toSlug(m);
              return (
                <MatchCard
                  id={m.id}
                  slug={mSlug}
                  title={`${m.league}: ${m.teams}`}
                  league={m.league}
                  teams={m.teams}
                  time={m.time}
                  date={m.date}
                  channels={m.channels}
                />
              );
            })}
          </div>
        </div>
      )}
    </aside>
  </div>
</Base>
