---
import Base from '../../layouts/Base.astro';
import MatchPlayer from '../../components/MatchPlayer.astro';
import MatchCard from '../../components/MatchCard.astro';
import LocalTime from '../../components/LocalTime.astro';
import matchDataRaw from '../../data/matches.json';

const allMatches = matchDataRaw.data || [];

// Helper functions
function parseMatch(event) {
  const desc = (event.attributes?.diary_description || '').trim().replace(/\s+/g, ' ');
  const colonIdx = desc.indexOf(':');
  const league = colonIdx > -1 ? desc.slice(0, colonIdx).trim() : '';
  const teams = colonIdx > -1 ? desc.slice(colonIdx + 1).trim() : desc;
  return { league, teams };
}

function toSlug(event) {
  const desc = (event.attributes?.diary_description || '')
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

function getCountry(event) {
  const countryData = event.attributes?.country?.data?.attributes;
  return {
    name: countryData?.name || 'Internacional',
    flagUrl: countryData?.image?.data?.attributes?.url || '',
  };
}

function getEmbeds(event) {
  const embeds = event.attributes?.embeds?.data || [];
  return embeds.map(e => ({
    name: e.attributes?.embed_name || 'Canal',
    url: e.attributes?.decoded_iframe_url || '',
  })).filter(e => e.url);
}

function getChannels(event) {
  const embeds = event.attributes?.embeds?.data || [];
  return embeds.map(e => e.attributes?.embed_name || 'Canal').filter(Boolean);
}

// Generate static paths for all matches
export function getStaticPaths() {
  const matchData = matchDataRaw;
  const matches = matchData.data || [];

  return matches.map((event) => {
    const desc = (event.attributes?.diary_description || '')
      .toLowerCase().trim().replace(/\s+/g, ' ')
      .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
    const slug = `${event.id}-${desc}`;
    return { params: { slug }, props: { event } };
  });
}

const { event } = Astro.props;
const { league, teams } = parseMatch(event);
const country = getCountry(event);
const embeds = getEmbeds(event);
const hour = event.attributes?.diary_hour || '';
const date = event.attributes?.date_diary || '';
const slug = toSlug(event);

// Related matches (up to 4 others from same day)
const relatedMatches = allMatches
  .filter(m => m.id !== event.id)
  .slice(0, 4);

const title = `${teams} en Vivo 🔴 ${league} | Rojadirecta Tarjeta Roja`;
const description = `Ver ${teams} en vivo gratis. ${league} en directo por rojadirecta, tarjeta roja, pirlo tv. Partido en vivo hoy ${date}.`;
const canonicalUrl = `https://rojadirectaenvivo.top/partido/${slug}/`;

const sportsEventSchema = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": teams,
  "description": `Ver ${teams} en vivo gratis. ${league} en directo.`,
  "startDate": `${date}T${hour}-03:00`,
  "sport": "Fútbol",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": {
    "@type": "VirtualLocation",
    "url": canonicalUrl
  },
  "organizer": {
    "@type": "Organization",
    "name": league
  }
};
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} matchSchema={sportsEventSchema}>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <span>›</span>
    <span>{country.name}</span>
    <span>›</span>
    <span class="text-on-surface/70">{teams}</span>
  </nav>

  <div class="lg:grid lg:grid-cols-[1fr_320px] lg:gap-8">
    <!-- Main content -->
    <div>
      <h1 class="text-2xl md:text-3xl font-black mb-2 text-on-surface">
        {teams} en Vivo
      </h1>
      <h2 class="text-on-surface/50 mb-6 text-sm">
        {league} – {date} – {hour} hora Argentina
      </h2>

      <!-- Player -->
      <MatchPlayer embeds={embeds} matchTitle={teams} />

      <!-- Match SEO text -->
      <section class="seo-text">
        <h2>Ver {teams} en Vivo Gratis</h2>
        <p>
          No te pierdas el partido de <strong>{teams}</strong> hoy por <strong>{league}</strong>.
          Mira la transmisión en vivo y en directo de este emocionante encuentro en
          <strong>Rojadirecta en Vivo</strong>, tu mejor opción para ver
          <strong>fútbol en vivo gratis</strong>, similar a <strong>Tarjeta Roja</strong> y <strong>Pirlo TV</strong>.
        </p>
        <p>
          Disfruta de la <strong>roja directa</strong> del partido {teams} de {league}
          sin interrupciones. Todos los canales disponibles están listados arriba —
          haz clic en cualquier canal para cambiar la transmisión.
          En <strong>rojadirectaenvivo.top</strong> encontrarás todos los partidos del día en vivo.
        </p>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="mt-8 lg:mt-0">
      <div class="bg-surface-variant rounded-2xl border border-white/5 p-5 mb-6">
        <h3 class="text-sm font-bold text-on-surface/70 uppercase tracking-wider mb-4">Información del Partido</h3>

        <div class="space-y-3 text-sm">
          <div class="flex items-center gap-3">
            {country.flagUrl && (
              <img src={country.flagUrl} alt={`Bandera de ${country.name}`} width="24" height="18" class="rounded-sm" />
            )}
            <span class="text-on-surface/70">{country.name}</span>
          </div>

          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-on-surface/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-on-surface/70">{league}</span>
          </div>

          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-on-surface/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-on-surface/70">{hour} hora Argentina</span>
          </div>

          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-on-surface/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-on-surface/70">{date}</span>
          </div>

          <div class="pt-2">
            <LocalTime hour={hour} date={date} id={String(event.id)} />
          </div>
        </div>

        {embeds.length > 0 && (
          <div class="mt-4 pt-4 border-t border-white/5">
            <h4 class="text-xs font-bold text-on-surface/50 uppercase mb-2">Canales Disponibles</h4>
            <div class="flex flex-wrap gap-1.5">
              {embeds.map(e => (
                <span class="channel-badge">{e.name}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Related matches -->
      {relatedMatches.length > 0 && (
        <div>
          <h3 class="text-sm font-bold text-on-surface/70 uppercase tracking-wider mb-4">Ver más partidos</h3>
          <div class="space-y-3">
            {relatedMatches.map((m) => {
              const parsed = parseMatch(m);
              const mCountry = getCountry(m);
              const mChannels = getChannels(m);
              const mSlug = toSlug(m);
              return (
                <MatchCard
                  id={m.id}
                  slug={mSlug}
                  title={m.attributes?.diary_description || ''}
                  league={parsed.league}
                  teams={parsed.teams}
                  hour={m.attributes?.diary_hour || ''}
                  date={m.attributes?.date_diary || ''}
                  country={mCountry.name}
                  flagUrl={mCountry.flagUrl}
                  channels={mChannels}
                />
              );
            })}
          </div>
        </div>
      )}
    </aside>
  </div>
</Base>
