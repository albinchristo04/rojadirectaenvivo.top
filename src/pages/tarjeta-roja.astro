---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';

import matchDataRaw from '../data/matches.json';

const events = matchDataRaw.events || [];

function toSlug(event: any) {
  const desc = `${event.league} ${event.teams}`
    .toLowerCase().trim().replace(/\s+/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
  return `${event.id}-${desc}`;
}

const title = 'Tarjeta Roja TV – Fútbol en Vivo | Rojadirecta Pirlo TV';
const description = 'Tarjeta Roja TV para ver fútbol en vivo gratis. Todos los partidos del día en directo - Rojadirecta, Pirlo TV, roja directa.';
const canonicalUrl = 'https://rojadirectaenvivo.top/tarjeta-roja/';
---

<Base title={title} description={description} canonicalUrl={canonicalUrl}>
  <div class="container">
    <section class="keyword-hero">
      <h1 class="keyword-h1">Tarjeta Roja</h1>
      <p class="keyword-sub">Ver partidos en vivo gratis — fútbol en directo sin interrupciones</p>
    </section>

    <div class="keyword-text">
      <p>
        <strong>Tarjeta Roja</strong> es uno de los nombres más conocidos en el mundo del streaming de fútbol en vivo.
        En <strong>rojadirectaenvivo.top</strong> te ofrecemos la misma experiencia que <strong>Tarjeta Roja TV</strong>
        con una interfaz moderna y actualizada. Aquí puedes ver todos los partidos del día sin registro y completamente gratis.
      </p>

      <p>
        Si buscas <strong>tarjeta roja en vivo</strong>, has llegado al lugar correcto. Nuestra plataforma reúne
        múltiples fuentes de transmisión para que puedas disfrutar del fútbol en directo sin interrupciones.
        Ya sea LaLiga, Premier League, Champions League, Copa Libertadores o cualquier otra competición,
        la <strong>tarjeta roja directa</strong> está aquí para ti.
      </p>

      <p>
        A diferencia de otros sitios, en <strong>Tarjeta Roja</strong> de rojadirectaenvivo.top ofrecemos
        varias opciones de canales por partido. Si un canal no funciona, simplemente cambia al siguiente.
        Nuestro contenido se actualiza automáticamente cada 3 horas con los últimos partidos disponibles.
        <strong>Rojadirecta</strong> y <strong>Pirlo TV</strong> son algunas de las alternativas que también
        encontrarás en nuestra plataforma.
      </p>

      <p>
        Ver <strong>fútbol en vivo gratis</strong> nunca fue tan sencillo. Con <strong>Tarjeta Roja TV</strong>
        en rojadirectaenvivo.top tienes acceso a partidos de todo el mundo, desde ligas sudamericanas
        hasta las mejores competiciones europeas. Todo el <strong>futbol en vivo</strong> en un solo lugar,
        sin pagar, sin registrarse, solo <strong>roja directa</strong> pura.
      </p>
    </div>

    <h2 class="keyword-text-title">Partidos de Hoy</h2>

    {events.length > 0 ? (
      <div class="match-grid">
        {events.map((event: any) => {
          const slug = toSlug(event);
          return (
            <MatchCard
              id={event.id}
              slug={slug}
              title={`${event.league}: ${event.teams}`}
              league={event.league}
              teams={event.teams}
              time={event.time}
              date={event.date}
              channels={event.channels}
            />
          );
        })}
      </div>
    ) : (
      <p style="color: var(--c-text-secondary);">No hay partidos disponibles en este momento.</p>
    )}
  </div>
</Base>
