---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQ from '../components/FAQ.astro';
import RelatedMatches from '../components/RelatedMatches.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { getMatches } from '../utils/matches';

const events = getMatches();

const title = 'Pirlo TV en Vivo – Fútbol Online Gratis | Rojadirecta Tarjeta Roja';
const description = 'Pirlo TV en vivo para ver fútbol online gratis. Todos los partidos del día en directo - Rojadirecta, Tarjeta Roja, roja directa.';
const canonicalUrl = 'https://rojadirectaenvivo.top/pirlo-tv/';

const breadcrumbs = [
  { name: 'Inicio', url: 'https://rojadirectaenvivo.top/' },
  { name: 'Pirlo TV', url: canonicalUrl },
];

const faqs = [
  {
    question: '¿Qué es Pirlo TV?',
    answer: 'Pirlo TV es una plataforma popular para ver fútbol en vivo gratis. En rojadirectaenvivo.top ofrecemos la misma experiencia con transmisiones actualizadas y múltiples canales por partido.',
  },
  {
    question: '¿Pirlo TV sigue funcionando?',
    answer: 'El sitio original de Pirlo TV ha cambiado varias veces. En rojadirectaenvivo.top mantenemos la experiencia de PirloTV con una plataforma estable y actualizada.',
  },
  {
    question: '¿Pirlo TV es seguro?',
    answer: 'rojadirectaenvivo.top es seguro para navegar. Nuestra plataforma no requiere descargas ni registros para ver los partidos en vivo.',
  },
];

const internalLinks = [
  { label: '⚽ Fútbol Libre', href: '/futbol-libre/' },
  { label: '⚽ Fútbol en Vivo', href: '/futbol-en-vivo/' },
  { label: '🔴 Rojadirecta en Vivo', href: '/rojadirecta-en-vivo/' },
  { label: '🟥 Tarjeta Roja', href: '/tarjeta-roja/' },
  { label: '📅 Partidos de Hoy', href: '/partidos-de-hoy/' },
  { label: '🆓 Fútbol en Vivo Gratis', href: '/futbol-en-vivo-gratis/' },
  { label: '👀 Ver Fútbol Online', href: '/ver-futbol/' },
];
---

<Base title={title} description={description} canonicalUrl={canonicalUrl}>
  <div class="container" style="padding-top: 32px;">
    <Breadcrumb items={breadcrumbs} />

    <section class="keyword-hero">
      <h1 class="keyword-h1">Pirlo TV</h1>
      <p class="keyword-sub">Rojadirecta en vivo gratis — fútbol online sin registro</p>
    </section>

    <div class="keyword-text">
      <p>
        <strong>Pirlo TV</strong> ha sido durante años uno de los sitios más populares para ver
        <strong>fútbol en vivo gratis</strong> en español. En <strong>rojadirectaenvivo.top</strong>
        ofrecemos la misma experiencia y calidad que <strong>PirloTV</strong> con todas las
        transmisiones del día actualizadas automáticamente.
      </p>

      <p>
        Si estás buscando <strong>pirlo tv rojadirecta</strong>, aquí encontrarás exactamente lo que necesitas.
        Nuestra plataforma combina lo mejor de <strong>Pirlo TV</strong>, <strong>Rojadirecta</strong> y
        <strong>Tarjeta Roja</strong> en un solo lugar. Cada partido tiene múltiples opciones de canales
        para que siempre puedas encontrar una transmisión que funcione perfectamente.
      </p>

      <p>
        <strong>PirloTV</strong> en rojadirectaenvivo.top cubre todas las competiciones importantes:
        LaLiga Santander, Premier League, Serie A de Italia, Bundesliga, Ligue 1, Liga MX,
        Liga Profesional Argentina, Copa Libertadores, Copa Sudamericana, Champions League,
        Europa League y Conference League. Todo el <strong>fútbol en vivo</strong> que puedas imaginar.
      </p>

      <p>
        No necesitas descargar ninguna aplicación ni registrarte para ver los partidos.
        <strong>Pirlo TV en vivo</strong> funciona directamente en tu navegador, ya sea desde
        tu computadora, tablet o celular. La <strong>roja directa</strong> del fútbol mundial
        está al alcance de tu mano. Disfruta de <strong>livetv</strong> deportivo con la mejor
        calidad y sin interrupciones en <strong>rojadirectaenvivo.top</strong>.
      </p>
    </div>

    <RelatedMatches matches={events} title="Partidos de Hoy" />

    <FAQ items={faqs} />

    <InternalLinks links={internalLinks} />

    <div style="text-align: center; margin-top: 32px; margin-bottom: 32px;">
      <a href="/" style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
        ← Ver todos los partidos
      </a>
      <span style="margin: 0 16px; color: var(--c-text-muted);">|</span>
      <a href="/tarjeta-roja/" style="color: var(--c-accent); text-decoration: none; font-weight: 600;">
        Tarjeta Roja →
      </a>
    </div>
  </div>
</Base>
