---
export interface Props {
  id: number;
  slug: string;
  title: string;
  league: string;
  teams: string;
  time: string;
  date: string;
  channels: { id: string; lang: string; name: string; url: string }[];
  isLive?: boolean;
}

const { id, slug, title, league, teams, time, date, channels, isLive } = Astro.props;

// Split teams for display
const teamParts = teams.split(/\s+vs\.?\s+/i);
const teamA = teamParts[0]?.trim() || teams;
const teamB = teamParts[1]?.trim() || '';
---

<a href={`/partido/${slug}/`} class={`match-card ${isLive ? 'is-live' : ''}`} id={`match-${id}`}>
  <div class="card-league">{league}</div>

  {isLive && (
    <div class="live-badge">
      <span class="live-dot"></span>
      EN VIVO
    </div>
  )}

  <div class="card-teams">
    <span class="team-a">{teamA}</span>
    {teamB && (
      <>
        <span class="card-vs">VS</span>
        <span class="team-b">{teamB}</span>
      </>
    )}
  </div>

  <div class="card-meta">
    <span>⏰ {time} ARG</span>
    <span class="card-local-time" data-hour={time} data-date={date}>· Tu hora: --:--</span>
  </div>

  <div class="card-footer">
    <div class="card-channels">
      {channels.slice(0, 2).map((ch) => (
        <span class="channel-badge">{ch.name}</span>
      ))}
      {channels.length > 2 && (
        <span class="channel-badge extra">+{channels.length - 2}</span>
      )}
    </div>
    <span class="card-cta">▶ VER</span>
  </div>
</a>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.card-local-time').forEach(el => {
      try {
        const hour = el.dataset.hour;
        const date = el.dataset.date;
        if (!hour || !date) return;

        const parts = date.split('-');
        const isoDate = parts.length === 3 ? `${parts[2]}-${parts[1]}-${parts[0]}` : date;

        const [h, m] = hour.split(':');
        const argDate = new Date(`${isoDate}T${h.padStart(2, '0')}:${m.padStart(2, '0')}:00-03:00`);
        const localTime = argDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        el.textContent = `· Tu hora: ${localTime}`;
      } catch {
        el.textContent = '· Tu hora: --:--';
      }
    });
  });
</script>
