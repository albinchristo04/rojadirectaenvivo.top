<!-- Monetag Popunder — zone 10848709 -->
<!-- Fires on first user interaction (click/tap) for maximum impression rate -->
<script is:inline>
(function(){
  var fired = false;
  function loadPopunder() {
    if (fired) return;
    fired = true;
    (function(s){
      s.dataset.zone='10848709';
      s.src='https://al5sm.com/tag.min.js';
    })([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')));
  }
  // Fire on first click/tap anywhere on the page
  document.addEventListener('click', loadPopunder, { once: true });
  document.addEventListener('touchend', loadPopunder, { once: true });
  // Also fire after 5s of dwell time (catches users who don't click)
  setTimeout(loadPopunder, 5000);
})();
</script>
