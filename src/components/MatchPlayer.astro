---
export interface Channel {
  id: string;
  lang: string;
  name: string;
  url: string;
}

export interface Props {
  channels: Channel[];
  matchTitle: string;
}

const { channels, matchTitle } = Astro.props;
const hasChannels = channels && channels.length > 0;
const primaryChannel = hasChannels ? channels[0] : null;
---

<div class="match-player">
  {hasChannels && primaryChannel && (
    <div class="player-wrapper">
      <div class="player-aspect" id="player-container" data-src={primaryChannel.url} data-title={`Ver ${matchTitle} en vivo`}>
        <noscript>
          <iframe
            src={primaryChannel.url}
            title={`Ver ${matchTitle} en vivo`}
            scrolling="no"
            allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
          ></iframe>
        </noscript>
      </div>
      <p class="vpn-hint">
        🔒 Si no puedes ver el streaming, usa una VPN gratuita.
        <a href="https://1.1.1.1/" target="_blank" rel="noopener">Descargar 1.1.1.1 (WARP VPN gratis)</a>
      </p>
    </div>
  )}

  {hasChannels && channels.length > 1 && (
    <div class="channel-tabs" role="tablist" aria-label="Canales disponibles">
      {channels.map((ch, i) => (
        <button
          class={`ch-tab ${i === 0 ? 'active' : ''}`}
          data-url={ch.url}
          role="tab"
          type="button"
        >
          <span class="ch-num">{i + 1}</span>
          <span class="ch-name">{ch.name}</span>
        </button>
      ))}
    </div>
  )}

  {!hasChannels && (
    <div class="no-channels">
      <p>Este partido no tiene transmisión disponible aún.</p>
    </div>
  )}
</div>

