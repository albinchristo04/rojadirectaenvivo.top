---
export interface Channel {
  id: string;
  lang: string;
  name: string;
  url: string;
}

export interface Props {
  channels: Channel[];
  matchTitle: string;
}

const { channels, matchTitle } = Astro.props;
const hasChannels = channels && channels.length > 0;
const primaryChannel = hasChannels ? channels[0] : null;
---

<div class="match-player">
  {hasChannels && primaryChannel && (
    <div class="player-wrapper">
      <div class="player-aspect" id="player-container" data-src={primaryChannel.url} data-title={`Ver ${matchTitle} en vivo`}>
        <noscript>
          <iframe
            src={primaryChannel.url}
            title={`Ver ${matchTitle} en vivo`}
            scrolling="no"
            allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
          ></iframe>
        </noscript>
      </div>
      <p class="vpn-hint">
        🔒 Si no puedes ver el streaming, usa una VPN gratuita.
        <a href="https://1.1.1.1/" target="_blank" rel="noopener">Descargar 1.1.1.1 (WARP VPN gratis)</a>
      </p>
    </div>
  )}

  <div class="telegram-cta">
    <a href="https://t.me/tarjetarojaenvivo" target="_blank" rel="noopener" class="telegram-btn">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      Únete a nuestro Telegram para más partidos en vivo
    </a>
  </div>

  {hasChannels && channels.length > 1 && (
    <div class="channel-tabs" role="tablist" aria-label="Canales disponibles">
      {channels.map((ch, i) => (
        <button
          class={`ch-tab ${i === 0 ? 'active' : ''}`}
          data-url={ch.url}
          role="tab"
          type="button"
        >
          <span class="ch-num">{i + 1}</span>
          <span class="ch-name">{ch.name}</span>
        </button>
      ))}
    </div>
  )}

  {!hasChannels && (
    <div class="no-channels">
      <p>Este partido no tiene transmisión disponible aún.</p>
    </div>
  )}
</div>

<style>
  .telegram-cta {
    margin: 12px 0 4px;
    text-align: center;
  }
  .telegram-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #229ED9;
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    padding: 10px 20px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .telegram-btn:hover {
    background: #1a8bbf;
  }
</style>

