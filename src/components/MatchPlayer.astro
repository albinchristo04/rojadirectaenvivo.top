---
export interface Channel {
  id: string;
  lang: string;
  name: string;
  url: string;
}

export interface Props {
  channels: Channel[];
  matchTitle: string;
}

const { channels, matchTitle } = Astro.props;
const hasChannels = channels && channels.length > 0;
const primaryChannel = hasChannels ? channels[0] : null;
---

<div class="match-player">
  {hasChannels && primaryChannel && (
    <div class="player-wrapper">
      <div class="player-aspect">
        <iframe
          id="match-iframe"
          src={primaryChannel.url}
          title={`Ver ${matchTitle} en vivo`}
          allowfullscreen
          scrolling="no"
          loading="lazy"
          referrerpolicy="no-referrer"
          allow="autoplay; encrypted-media; fullscreen"
        ></iframe>
      </div>
    </div>
  )}

  {hasChannels && channels.length > 1 && (
    <div class="channel-tabs" role="tablist" aria-label="Canales disponibles">
      {channels.map((ch, i) => (
        <button
          class={`ch-tab ${i === 0 ? 'active' : ''}`}
          data-url={ch.url}
          role="tab"
          type="button"
        >
          <span class="ch-num">{i + 1}</span>
          <span class="ch-name">{ch.name}</span>
        </button>
      ))}
    </div>
  )}

  {!hasChannels && (
    <div class="no-channels">
      <p>Este partido no tiene transmisión disponible aún.</p>
    </div>
  )}
</div>

<script is:inline>
  document.querySelectorAll('.ch-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var iframe = document.querySelector('#match-iframe');
      if (iframe) iframe.src = tab.dataset.url;
      document.querySelectorAll('.ch-tab').forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
    });
  });
</script>
