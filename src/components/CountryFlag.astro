---
export interface Props {
  src: string;
  country: string;
  width?: number;
  height?: number;
}

const { src, country, width = 24, height = 18 } = Astro.props;
---

{src ? (
  <img
    src={src}
    alt={`Bandera de ${country}`}
    width={width}
    height={height}
    loading="lazy"
    class="rounded-sm object-cover inline-block"
  />
) : (
  <span class="inline-block w-6 h-4 bg-white/10 rounded-sm"></span>
)}
