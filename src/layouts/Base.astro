---
export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  matchSchema?: object;
}

const { title, description, canonicalUrl, matchSchema } = Astro.props;

import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="theme-color" content="#E8001D" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet" />
  {matchSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(matchSchema)} />
  )}
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo"><span>ROJA</span>DIRECTAENVIVO</a>

      <!-- Desktop nav -->
      <ul class="nav-desktop">
        <li><a href="/">Inicio</a></li>
        <li><a href="/rojadirecta-en-vivo/">Rojadirecta en Vivo</a></li>
        <li><a href="/tarjeta-roja/">Tarjeta Roja</a></li>
        <li><a href="/pirlo-tv/">Pirlo TV</a></li>
      </ul>

      <!-- Mobile menu (CSS-only) -->
      <input type="checkbox" id="mobile-toggle" class="mobile-menu-toggle" aria-label="Menú" />
      <label for="mobile-toggle" class="mobile-menu-label" aria-label="Abrir menú">
        <span></span>
      </label>
      <ul class="nav-mobile">
        <li><a href="/">Inicio</a></li>
        <li><a href="/rojadirecta-en-vivo/">Rojadirecta en Vivo</a></li>
        <li><a href="/tarjeta-roja/">Tarjeta Roja</a></li>
        <li><a href="/pirlo-tv/">Pirlo TV</a></li>
      </ul>
    </div>
  </header>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-logo">ROJA<span>DIRECTAENVIVO</span></div>
    <nav class="footer-nav">
      <a href="/rojadirecta-en-vivo/">Rojadirecta en Vivo</a>
      <a href="/tarjeta-roja/">Tarjeta Roja</a>
      <a href="/pirlo-tv/">Pirlo TV</a>
    </nav>
    <p class="footer-seo">
      Ver fútbol en vivo gratis — Rojadirecta · Tarjeta Roja TV · Pirlo TV · Roja Directa
    </p>
    <p class="footer-disclaimer">
      Este sitio no aloja ningún contenido. Todos los streams son proporcionados por terceros.
    </p>
  </footer>
</body>
</html>
