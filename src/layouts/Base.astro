---
import PopupAds from '../components/PopupAds.astro';

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  matchSchema?: object;
  ogImage?: string;
}

const { title, description, canonicalUrl, matchSchema, ogImage } = Astro.props;
const resolvedOgImage = ogImage || 'https://rojadirectaenvivo.top/og-default.png';

import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={resolvedOgImage} />
  <meta name="theme-color" content="#E8001D" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet" />
  {matchSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(matchSchema)} />
  )}
  <slot name="head" />
  <!-- Clarity tracking code for https://rojadirectaenvivo.top/ -->
  <script is:inline>
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i+"?ref=bwt";
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "w0lrniwx5e");
  </script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FV3Y2685HK"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FV3Y2685HK');
  </script>
</head>
<body>
  <!-- Header -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo"><span>ROJA</span>DIRECTAENVIVO</a>

      <!-- Desktop nav -->
      <ul class="nav-desktop">
        <li><a href="/">Inicio</a></li>
        <li><a href="/hoy/">Hoy</a></li>
        <li><a href="/futbol-libre/">Fútbol Libre</a></li>
        <li><a href="/futbol-en-vivo/">Fútbol en Vivo</a></li>
        <li><a href="/rojadirecta-en-vivo/">Rojadirecta</a></li>
        <li><a href="/tarjeta-roja/">Tarjeta Roja</a></li>
        <li><a href="/pirlo-tv/">Pirlo TV</a></li>
      </ul>

      <!-- Mobile menu (CSS-only) -->
      <input type="checkbox" id="mobile-toggle" class="mobile-menu-toggle" aria-label="Menú" />
      <label for="mobile-toggle" class="mobile-menu-label" aria-label="Abrir menú">
        <span></span>
      </label>
      <ul class="nav-mobile">
        <li><a href="/">Inicio</a></li>
        <li><a href="/hoy/">Hoy</a></li>
        <li><a href="/futbol-libre/">Fútbol Libre</a></li>
        <li><a href="/futbol-en-vivo/">Fútbol en Vivo</a></li>
        <li><a href="/rojadirecta-en-vivo/">Rojadirecta</a></li>
        <li><a href="/tarjeta-roja/">Tarjeta Roja</a></li>
        <li><a href="/pirlo-tv/">Pirlo TV</a></li>
      </ul>
    </div>
  </header>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-logo">ROJA<span>DIRECTAENVIVO</span></div>
    <nav class="footer-nav">
      <a href="/hoy/">Partidos de Hoy</a>
      <a href="/futbol-libre/">Fútbol Libre</a>
      <a href="/futbol-en-vivo/">Fútbol en Vivo</a>
      <a href="/futbol-en-vivo-gratis/">Fútbol en Vivo Gratis</a>
      <a href="/ver-futbol/">Ver Fútbol Online</a>
      <a href="/partidos-de-hoy/">Partidos de Hoy en Vivo</a>
      <a href="/rojadirecta-en-vivo/">Rojadirecta en Vivo</a>
      <a href="/tarjeta-roja/">Tarjeta Roja</a>
      <a href="/pirlo-tv/">Pirlo TV</a>
      <a href="/webmasters/">Webmasters</a>
    </nav>
    <p class="footer-seo">
      Ver fútbol en vivo gratis — Fútbol Libre · Rojadirecta · Tarjeta Roja TV · Pirlo TV · Roja Directa · Partidos de Hoy
    </p>
    <p class="footer-disclaimer">
      Este sitio no aloja ningún contenido. Todos los streams son proporcionados por terceros.
    </p>
  </footer>

  <PopupAds />
</body>
</html>
